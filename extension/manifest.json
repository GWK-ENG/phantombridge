{
    "manifest_version": 3,
    "name": "PhantomBridge",
    "version": "0.1.0",
    "description": "AI Agent 浏览器底层控制网关 - 专为 AI 和自动化打造的浏览器运行时环境",
    "permissions": [
        "nativeMessaging",
        "debugger",
        "tabs",
        "activeTab",
        "scripting",
        "sidePanel",
        "storage"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' ws://localhost:7778 http://localhost:7778 ws://127.0.0.1:7778 http://127.0.0.1:7778;"
    },
    "background": {
        "service_worker": "background.js"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "action": {
        "default_title": "PhantomBridge"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content-early.js"
            ],
            "run_at": "document_start",
            "all_frames": false
        },
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle",
            "all_frames": false
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}